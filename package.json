{
  "name": "pw-manager",
  "version": "1.0.0",
  "description": "Desktop password manager (Electron)",
  "main": "dist/main.js",
  "scripts": {
    "build:main": "tsc",
    "build:renderer": "tsc -p src/renderer/tsconfig.json",
    "copy:assets": "node -e \"const fs=require('fs');fs.mkdirSync('dist/renderer',{recursive:true});fs.copyFileSync('src/renderer/index.html','dist/renderer/index.html');fs.copyFileSync('src/renderer/styles.css','dist/renderer/styles.css');\"",
    "build": "npm run build:main && npm run build:renderer && npm run copy:assets",
    "start": "npm run build && electron .",
    "rebuild": "electron-rebuild"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gandolh/pw-manager.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/gandolh/pw-manager/issues"
  },
  "homepage": "https://github.com/gandolh/pw-manager#readme",
  "dependencies": {
    "better-sqlite3": "12.10.0"
  },
  "devDependencies": {
    "@electron/rebuild": "4.0.4",
    "@types/better-sqlite3": "7.6.13",
    "@types/node": "25.9.1",
    "electron": "41.7.0",
    "typescript": "6.0.3"
  }
}
